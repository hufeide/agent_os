{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: 启动Agent OS",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/start.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": true
    },
    {
      "name": "Python: 调试主Agent",
      "type": "debugpy",
      "request": "launch",
      "module": "agents.main_agent",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": []
    },
    {
      "name": "Python: 调试子Agent Worker",
      "type": "debugpy",
      "request": "launch",
      "module": "agents.sub_agent_worker",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": []
    },
    {
      "name": "Python: 调试任务调度器",
      "type": "debugpy",
      "request": "launch",
      "module": "core.task_scheduler",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": []
    },
    {
      "name": "Python: 调试事件总线",
      "type": "debugpy",
      "request": "launch",
      "module": "core.event_bus",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": []
    },
    {
      "name": "Python: 调试黑板系统",
      "type": "debugpy",
      "request": "launch",
      "module": "core.blackboard",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": []
    },
    {
      "name": "Python: 调试技能注册表",
      "type": "debugpy",
      "request": "launch",
      "module": "core.skill_registry",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": []
    },
    {
      "name": "Python: 调试向量记忆",
      "type": "debugpy",
      "request": "launch",
      "module": "core.vector_memory",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": []
    },
    {
      "name": "Python: 调试API服务器",
      "type": "debugpy",
      "request": "launch",
      "module": "api.server",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": []
    },
    {
      "name": "Python: 调试任务调试工具",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/debug_task.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": []
    },
    {
      "name": "Python: 附加到运行中的进程",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "."
        }
      ]
    },
    {
      "name": "Python: 当前文件",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": true
    }
  ]
}